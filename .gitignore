# =========================
# ENV & SECRETS (CRITICAL)
# =========================
.env
.env.*
*.env
env/.env
inference-service/.env
worker-service/.env
server/.env
client/.env
minikube-linux-amd64

# API keys / secrets
*.pem
*.key
*.crt
secrets.yaml
k8s/*secret*.yaml

# =========================
# PYTHON
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
*.sqlite3

# virtual environments
# ignore only virtual env
env/venv/
env/Lib/
env/Scripts/
env/bin/

# but allow code
!env/*.py
!env/server/

# =========================
